{
  "name": "ropecon-game-finder",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --filter @ropecon/web dev",
    "stop": "bun --filter @ropecon/web stop",
    "build": "bun run build:web && bun run build:job",
    "build:web": "bun --filter @ropecon/web build",
    "build:job": "bun --filter @ropecon/program-refresh build",
    "test": "bun run --filter '*' test",
    "typecheck": "bun run --filter '*' typecheck",
    "audit:report": "bun scripts/audit-konsti.ts report",
    "audit:check": "bun scripts/audit-konsti.ts check",
    "venue:check": "bun scripts/venue-check.ts",
    "check:no-fallback": "! rg -n '/program[.]json' apps/web/src apps/web/public"
  },
  "devDependencies": {
    "@ropecon/program-core": "workspace:*",
    "@types/node": "^24.0.0",
    "typescript": "^5.9.3"
  }
}
