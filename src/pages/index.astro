---
/**
 * Steps 5–8 — the guest-facing render (handoff §"Step 5"/§"Step 6"/§8).
 *
 * Renders the full gaming list end to end from the baked `program.json`: title,
 * time (Europe/Helsinki), location (linked to the convention map), signup mode with
 * its participation affordance, cancellation, and capacity state. Step 6 adds the
 * client-side time-window filter; Step 8 finalises the signup/participation copy
 * (walk-in / Konsti direct-vs-lottery / physical desk), full & cancelled markers,
 * revolving-door copy, the "Open now (walk-ins)" view, and first-run guidance.
 *
 * The page reads ONLY `program.json` (client contract, handoff Step 4) — never the raw
 * Konsti response. Copy is English-only for this first release; the config already
 * carries `labelFi`/`labelEn`, so bilingual FI/EN is a later, additive change.
 *
 * The envelope is read at build time from `public/program.json` (the artifact
 * `scripts/build-program.ts` bakes), so this is a purely static render.
 */
import { readFileSync } from "node:fs";
import { resolve } from "node:path";
import { conventionMapUrl } from "../config/venue.ts";
import type { ProgramData, ProgramItem } from "../normalise/types.ts";

// Read the baked artifact from the project root (cwd is stable during build,
// unlike import.meta.url which points at the bundled chunk).
const programPath = resolve(process.cwd(), "public/program.json");
const program = JSON.parse(readFileSync(programPath, "utf8")) as ProgramData;

// Europe/Helsinki display formatters (UTC instants in, con-local strings out).
const dayHeadingFmt = new Intl.DateTimeFormat("en-GB", {
  timeZone: "Europe/Helsinki",
  weekday: "long",
  day: "numeric",
  month: "long",
});
const timeFmt = new Intl.DateTimeFormat("en-GB", {
  timeZone: "Europe/Helsinki",
  hour: "2-digit",
  minute: "2-digit",
});
const stampFmt = new Intl.DateTimeFormat("en-GB", {
  timeZone: "Europe/Helsinki",
  dateStyle: "medium",
  timeStyle: "short",
});

const dayHeading = (day: string) => dayHeadingFmt.format(new Date(`${day}T12:00:00Z`));
const timeRange = (start: string, end: string) =>
  `${timeFmt.format(new Date(start))}–${timeFmt.format(new Date(end))}`;

// Fallback copy for a physical signupType with no configured location (a `warn`, never
// a hard failure — see config/signup.ts). Guests still get pointed somewhere real.
const PHYSICAL_FALLBACK_LABEL = "Signup at the info desk";
const PHYSICAL_FALLBACK_DETAIL = "Sign up on site — ask at the program information desk.";

/** The short signup-mode label shown in the Signup fact (primer §5 step 8). */
function signupLabel(item: ProgramItem): string {
  switch (item.signupMode) {
    case "none":
      return "No signup needed";
    case "konsti":
      return item.signupStrategy === "lottery" ? "Konsti lottery" : "Konsti signup";
    case "physical":
      return item.physicalSignupLocation?.labelEn ?? PHYSICAL_FALLBACK_LABEL;
  }
}

/**
 * The one-line explanation under the signup label (primer §5 step 8):
 *  - none:     walk in, nothing to do.
 *  - konsti:   direct-vs-lottery, so a lottery isn't read as a confirmed seat.
 *  - physical: where to sign up, in words — never an online action.
 */
function signupDetail(item: ProgramItem): string {
  switch (item.signupMode) {
    case "none":
      return "Just walk in — no signup required.";
    case "konsti":
      return item.signupStrategy === "lottery"
        ? "Lottery: a signup enters you in a draw — it does not confirm a seat."
        : "Direct signup: seats are given first come, first served.";
    case "physical":
      return item.physicalSignupLocation?.instructionsEn ?? PHYSICAL_FALLBACK_DETAIL;
  }
}

function capacityLabel(item: ProgramItem): string | null {
  switch (item.capacityStatus) {
    case "not-applicable":
      return null;
    case "available":
      return item.remainingSeats != null
        ? `${item.remainingSeats} of ${item.maxAttendance} seats left`
        : "Seats available";
    case "full":
      return "No seats left";
    case "unknown":
      return "Live seat count unavailable";
  }
}

/** A Konsti session known full — the one case that earns a scannable "Full" marker. */
const isKonstiFull = (item: ProgramItem) =>
  item.signupMode === "konsti" && item.capacityStatus === "full";

// Sort by start, then group into day sections for the render.
const sorted = [...program.items].sort((a, b) => a.start.localeCompare(b.start));
const days: { day: string; items: ProgramItem[] }[] = [];
for (const item of sorted) {
  const bucket = days.find((d) => d.day === item.day);
  if (bucket) bucket.items.push(item);
  else days.push({ day: item.day, items: [item] });
}

const generatedAt = stampFmt.format(new Date(program.generatedAt));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Ropecon Game Finder</title>
  </head>
  <body>
    <header class="page-header">
      <h1>Ropecon Game Finder</h1>
      <p class="meta">
        {program.items.length} gaming sessions · program as of {generatedAt} (Helsinki)
      </p>
      <p class="intro">
        Gaming sessions you can join, filtered to what's playable soon. This finder is
        read-only — it never signs you up: online signups open in <strong>Konsti</strong>,
        others are handled at a convention desk.
      </p>
      {/* Controls are JS-only: without JS the full list below renders unfiltered. */}
      <div class="controls" hidden>
        <div class="views" role="group" aria-label="View">
          <button type="button" class="view-btn" data-view="soon" aria-pressed="true">
            Joinable soon
          </button>
          <button type="button" class="view-btn" data-view="walkins" aria-pressed="false">
            Open now (walk-ins)
          </button>
          <button type="button" class="view-btn" data-view="all" aria-pressed="false">
            All sessions
          </button>
        </div>
        <p class="result-count" aria-live="polite"></p>
      </div>
      <p class="now-notice" hidden></p>
    </header>

    <main>
      {/* Text is set by the client script per active view; hidden without JS. */}
      <p class="empty-state" hidden></p>
      {
        days.map((group) => (
          <section class="day">
            <h2>{dayHeading(group.day)}</h2>
            <ul class="sessions">
              {group.items.map((item) => (
                <li
                  class:list={["session", { cancelled: item.isCancelled }]}
                  data-start={item.start}
                  data-end={item.end}
                  data-cancelled={String(item.isCancelled)}
                  data-revolving={String(item.isRevolvingDoor)}
                  data-signup-mode={item.signupMode}
                  data-capacity={item.capacityStatus}
                >
                  <div class="session-head">
                    <span class="time">{timeRange(item.start, item.end)}</span>
                    <h3 class="title">{item.title}</h3>
                    {item.isCancelled && <span class="badge cancelled-badge">Cancelled</span>}
                    {!item.isCancelled && isKonstiFull(item) && (
                      <span class="badge full-badge">Full</span>
                    )}
                  </div>
                  {!item.isCancelled && item.isRevolvingDoor && (
                    <p class="revolving-note">You can join mid-session.</p>
                  )}
                  {item.shortDescription && (
                    <p class="short">{item.shortDescription}</p>
                  )}
                  <dl class="facts">
                    <div>
                      <dt>Location</dt>
                      <dd>
                        {item.location ? (
                          <a href={conventionMapUrl(item.location)} rel="noopener">
                            {item.location}
                          </a>
                        ) : (
                          "—"
                        )}
                      </dd>
                    </div>
                    <div>
                      <dt>Signup</dt>
                      <dd>
                        <span class="signup-label">{signupLabel(item)}</span>
                        {item.signupMode === "konsti" && item.signupUrl && !item.isCancelled && (
                          <>
                            {" "}
                            <a class="konsti-link" href={item.signupUrl} rel="noopener">
                              open in Konsti
                            </a>
                          </>
                        )}
                        <span class="signup-detail">{signupDetail(item)}</span>
                      </dd>
                    </div>
                    {capacityLabel(item) && (
                      <div>
                        <dt>Capacity</dt>
                        <dd>{capacityLabel(item)}</dd>
                      </div>
                    )}
                  </dl>
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </main>
  </body>
</html>

<script>
  /**
   * Step 6/7/8 runtime: filter the already-prerendered list to a resolved "now".
   *
   * No fetch — every field the classifier needs is baked into `data-*` attributes on
   * each `.session`, so the client contract (only `program.json`, and here not even
   * that) holds and the list still renders with JS disabled. `?now=` overrides the
   * device clock for testing outside con dates (Step 7). Step 8 adds the third
   * "Open now (walk-ins)" view over the same pure classifiers.
   */
  import {
    classifyJoinableSoon,
    isWalkInNow,
    resolveNow,
    type TimeWindowInput,
  } from "../classify/window.ts";

  type View = "soon" | "walkins" | "all";

  const sessions = [...document.querySelectorAll<HTMLLIElement>(".session")].map((el) => ({
    el,
    input: {
      start: el.dataset.start ?? "",
      end: el.dataset.end ?? "",
      isCancelled: el.dataset.cancelled === "true",
      isRevolvingDoor: el.dataset.revolving === "true",
      signupMode: el.dataset.signupMode,
      capacityStatus: el.dataset.capacity,
    } as TimeWindowInput,
  }));
  const daySections = [...document.querySelectorAll<HTMLElement>(".day")];
  const controls = document.querySelector<HTMLElement>(".controls");
  const countEl = document.querySelector<HTMLElement>(".result-count");
  const emptyEl = document.querySelector<HTMLElement>(".empty-state");
  const nowNotice = document.querySelector<HTMLElement>(".now-notice");
  const viewButtons = [...document.querySelectorAll<HTMLButtonElement>(".view-btn")];

  const params = new URLSearchParams(location.search);
  const { nowMs, overridden } = resolveNow(params.get("now"), Date.now());

  const notationFmt = new Intl.DateTimeFormat("en-GB", {
    timeZone: "Europe/Helsinki",
    dateStyle: "medium",
    timeStyle: "short",
  });

  function ensureBadge(el: HTMLLIElement): HTMLSpanElement {
    let badge = el.querySelector<HTMLSpanElement>(".window-badge");
    if (!badge) {
      badge = document.createElement("span");
      badge.className = "badge window-badge";
      el.querySelector(".session-head")?.appendChild(badge);
    }
    return badge;
  }

  function windowLabel(overlap: string, startMs: number): string {
    if (overlap === "join-in-progress") return "In progress · join anytime";
    const mins = Math.round((startMs - nowMs) / 60_000);
    return mins <= 0 ? "Starting now" : `Starts in ${mins} min`;
  }

  const clearBadge = (el: HTMLLIElement) => el.querySelector(".window-badge")?.remove();

  // Hide any day heading whose sessions are all filtered out.
  function syncDayHeadings(): void {
    for (const section of daySections) {
      const anyVisible = [...section.querySelectorAll<HTMLLIElement>(".session")].some(
        (el) => !el.hidden,
      );
      section.hidden = !anyVisible;
    }
  }

  // Show every session (the honest baseline); the filtered views narrow from here.
  function revealAll(): void {
    for (const { el } of sessions) {
      el.hidden = false;
      clearBadge(el);
    }
    for (const section of daySections) section.hidden = false;
    if (emptyEl) emptyEl.hidden = true;
    if (countEl) countEl.textContent = `${sessions.length} sessions`;
  }

  // Apply a per-session predicate, badge the kept ones, and report the count/empty state.
  function applyFilter(
    keep: (input: TimeWindowInput) => { included: boolean; badge: string | null },
    summarise: (shown: number) => string,
    emptyText: string,
  ): void {
    let shown = 0;
    for (const { el, input } of sessions) {
      const { included, badge } = keep(input);
      el.hidden = !included;
      if (included) {
        shown += 1;
        if (badge) ensureBadge(el).textContent = badge;
        else clearBadge(el);
      } else {
        clearBadge(el);
      }
    }
    syncDayHeadings();
    if (emptyEl) {
      emptyEl.textContent = emptyText;
      emptyEl.hidden = shown > 0;
    }
    if (countEl) countEl.textContent = summarise(shown);
  }

  function render(view: View): void {
    if (view === "all") {
      revealAll();
    } else if (view === "walkins") {
      applyFilter(
        (input) => ({ included: isWalkInNow(input, nowMs), badge: "Happening now" }),
        (shown) => (shown === 0 ? "No walk-in games open now" : `${shown} open for walk-ins now`),
        "No walk-in games are running right now. Try Joinable soon or All sessions.",
      );
    } else {
      applyFilter(
        (input) => {
          const { included, overlap } = classifyJoinableSoon(input, nowMs);
          return {
            included,
            badge: included ? windowLabel(overlap, Date.parse(input.start)) : null,
          };
        },
        (shown) => (shown === 0 ? "No joinable sessions" : `${shown} joinable in the next hour`),
        "Nothing joinable in the next hour. Switch to All sessions to see the full program.",
      );
    }
  }

  function setView(view: View): void {
    for (const btn of viewButtons) {
      btn.setAttribute("aria-pressed", String(btn.dataset.view === view));
    }
    render(view);
  }

  // Reveal the JS-only controls and wire them up.
  controls?.removeAttribute("hidden");
  for (const btn of viewButtons) {
    btn.addEventListener("click", () => setView(btn.dataset.view as View));
  }
  if (overridden && nowNotice) {
    nowNotice.hidden = false;
    nowNotice.textContent = `Testing as if it were ${notationFmt.format(nowMs)} (Helsinki) · ?now= override active`;
  }

  setView("soon");
</script>

<style>
  :root {
    --fg: #1a1a1a;
    --muted: #666;
    --line: #e2e2e2;
    --accent: #7a1f2b;
  }

  body {
    font-family: system-ui, -apple-system, sans-serif;
    color: var(--fg);
    line-height: 1.4;
    max-width: 46rem;
    margin: 0 auto;
    padding: 1.5rem 1rem 4rem;
  }

  .page-header h1 {
    margin: 0 0 0.25rem;
    color: var(--accent);
  }

  .meta {
    margin: 0;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .day h2 {
    font-size: 1.1rem;
    margin: 2rem 0 0.5rem;
    padding-bottom: 0.25rem;
    border-bottom: 2px solid var(--line);
  }

  .sessions {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .session {
    padding: 0.9rem 0;
    border-bottom: 1px solid var(--line);
  }

  .session.cancelled {
    opacity: 0.6;
  }

  .session-head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem;
  }

  .time {
    font-variant-numeric: tabular-nums;
    color: var(--muted);
    font-size: 0.9rem;
    min-width: 6.5rem;
  }

  .title {
    margin: 0;
    font-size: 1.05rem;
  }

  .session.cancelled .title {
    text-decoration: line-through;
  }

  .badge {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    padding: 0.1rem 0.4rem;
    border-radius: 0.25rem;
  }

  .cancelled-badge {
    background: #fbe3e3;
    color: var(--accent);
  }

  .window-badge {
    background: #e7f0e7;
    color: #2f6b34;
  }

  .controls {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.75rem;
  }

  .views {
    display: inline-flex;
    border: 1px solid var(--line);
    border-radius: 0.4rem;
    overflow: hidden;
  }

  .view-btn {
    appearance: none;
    border: 0;
    background: #fff;
    color: var(--fg);
    font: inherit;
    font-size: 0.9rem;
    padding: 0.35rem 0.75rem;
    cursor: pointer;
  }

  .view-btn + .view-btn {
    border-left: 1px solid var(--line);
  }

  .view-btn[aria-pressed="true"] {
    background: var(--accent);
    color: #fff;
  }

  .result-count {
    margin: 0;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .now-notice {
    margin: 0.5rem 0 0;
    padding: 0.4rem 0.6rem;
    background: #fff6e0;
    border-radius: 0.3rem;
    font-size: 0.85rem;
    color: #7a5b00;
  }

  .empty-state {
    color: var(--muted);
    padding: 1.5rem 0;
  }

  .short {
    margin: 0.4rem 0 0.5rem;
    color: var(--fg);
  }

  .facts {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.15rem 0.75rem;
    margin: 0;
    font-size: 0.9rem;
  }

  .facts > div {
    display: contents;
  }

  .facts dt {
    color: var(--muted);
  }

  .facts dd {
    margin: 0;
  }

  .intro {
    margin: 0.75rem 0 0;
    font-size: 0.9rem;
    color: var(--fg);
  }

  a {
    color: var(--accent);
  }

  .full-badge {
    background: #f0dede;
    color: var(--accent);
  }

  .revolving-note {
    margin: 0.35rem 0 0;
    font-size: 0.85rem;
    font-weight: 600;
    color: #2f6b34;
  }

  .signup-detail {
    display: block;
    color: var(--muted);
    font-size: 0.85rem;
  }
</style>
