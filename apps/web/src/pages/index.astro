---
/**
 * Steps 5–9 — the guest-facing render (handoff §"Step 5"/§"Step 6"/§8/§9).
 *
 * Renders the full gaming list: title, time (Europe/Helsinki), location (linked to the
 * convention map), signup mode with its participation affordance, cancellation, and
 * capacity state. Step 6 adds the client-side time-window filter; Step 8 finalises the
 * signup/participation copy (walk-in / Konsti direct-vs-lottery / physical desk), full
 * & cancelled markers, revolving-door copy, the "Open now (walk-ins)" view, and
 * first-run guidance; Step 9 warns when the snapshot has aged past 15 minutes.
 *
 * The page reads ONLY the published `program.json` client contract (handoff Step 4) —
 * never the raw Konsti response. Since program.json is no longer baked into the build
 * (it is published to external storage by a separate job), the page fetches it at
 * runtime from PUBLIC_PROGRAM_DATA_URL, caches it in localStorage, and renders in the
 * browser. A service worker keeps a previously-loaded program available offline. Copy
 * is English-only for this first release; the config already carries `labelFi`/`labelEn`,
 * so bilingual FI/EN is a later, additive change.
 */
const programUrl = import.meta.env.PUBLIC_PROGRAM_DATA_URL;
if (!programUrl) throw new Error("PUBLIC_PROGRAM_DATA_URL is required");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="program-data-url" content={programUrl} />
    <title>Ropecon Game Finder</title>
  </head>
  <body>
    <header class="page-header">
      <h1>Ropecon Game Finder</h1>
      <p class="meta" id="status" aria-live="polite">Loading the latest program…</p>
      <p class="intro">
        Gaming sessions you can join, filtered to what's playable soon. This finder is
        read-only — it never signs you up: online signups open in <strong>Konsti</strong>,
        others are handled at a convention desk.
      </p>
      {/* Controls are JS-only: revealed by the client script once the program loads. */}
      <div class="controls" hidden>
        <div class="views" role="group" aria-label="View">
          <button type="button" class="view-btn" data-view="soon" aria-pressed="true">
            Joinable soon
          </button>
          <button type="button" class="view-btn" data-view="walkins" aria-pressed="false">
            Open now (walk-ins)
          </button>
          <button type="button" class="view-btn" data-view="slot" aria-pressed="false">
            My time slot
          </button>
          <button type="button" class="view-btn" data-view="all" aria-pressed="false">
            All sessions
          </button>
        </div>
        {/* "My time slot" picker (§6, issue-05): `from` = day + start time, `to` chosen
            relative to `from` via +Nh quick options (or an explicit Custom window). The
            day dropdowns and quick buttons are populated by the client script. */}
        <fieldset class="slot-picker" hidden>
          <legend>When are you free? (Helsinki time)</legend>
          <div class="slot-from">
            <label class="slot-field">
              <span>Day</span>
              <select data-slot-day></select>
            </label>
            <label class="slot-field">
              <span>Start time</span>
              <input type="time" step="900" data-slot-time />
            </label>
          </div>
          <div class="slot-to">
            <span class="slot-to-label" id="slot-to-label">For how long?</span>
            <div class="slot-quick" role="group" aria-labelledby="slot-to-label"></div>
            <div class="slot-custom" hidden>
              <label class="slot-field">
                <span>Until day</span>
                <select data-slot-to-day></select>
              </label>
              <label class="slot-field">
                <span>Until time</span>
                <input type="time" step="900" data-slot-to-time />
              </label>
            </div>
          </div>
          <p class="slot-echo" aria-live="polite" hidden></p>
          <p class="slot-error" role="alert" hidden></p>
        </fieldset>
        <p class="result-count" aria-live="polite"></p>
      </div>
      <p class="now-notice" hidden></p>
      {/* Step 9: revealed by the client script when the resolved snapshot is > 15 min old. */}
      <p class="stale-notice" role="alert" hidden></p>
    </header>

    <main>
      {/* Text is set by the client script per active view / load failure. */}
      <p class="empty-state" hidden></p>
      {/* Orientation for the legitimately-empty joinable-soon default (§6, UX #2):
          populated and revealed by the client script from the data-derived model. */}
      <section class="orientation" aria-live="polite" hidden></section>
      <div id="program"></div>
    </main>
    <noscript>This finder needs JavaScript to load the program from its published data service.</noscript>

    <script>
      /**
       * Client runtime (Steps 5–9): fetch the published snapshot, render the full list,
       * then filter it to a resolved "now".
       *
       * program.json is no longer available at build time, so the list is rendered here
       * from the fetched data (with a localStorage cache + offline service worker) rather
       * than server-rendered. Every field the classifier needs is written onto `data-*`
       * attributes on each `.session`, so the same pure classifiers drive the filter
       * views. `?now=` overrides the device clock for testing outside con dates (Step 7).
       */
      import type { ProgramData, ProgramItem } from "@ropecon/program-core";
      import { classifyVenue, resolveConMapLink } from "@ropecon/program-core";
      import { loadProgramData, localStorageProgramCache } from "../program/load.ts";
      import {
        classifyInWindow,
        classifyJoinableSoon,
        isWalkInNow,
        resolveNow,
        resolveWindow,
        type TimeWindowInput,
      } from "../classify/window.ts";
      import {
        conDays,
        defaultFromTime,
        resolveDefaultSelection,
        resolveSlot,
        selectionFromWindow,
        QUICK_HOURS,
        type QuickOption,
        type SlotSelection,
      } from "../classify/slot.ts";
      import { classifyFreshness } from "../classify/freshness.ts";
      import { buildOrientation, type OrientationModel } from "../classify/orientation.ts";

      type View = "soon" | "walkins" | "slot" | "all";

      // ---- Element handles -------------------------------------------------------------

      const statusEl = document.querySelector<HTMLElement>("#status")!;
      const programRoot = document.querySelector<HTMLElement>("#program")!;
      const controls = document.querySelector<HTMLElement>(".controls");
      const countEl = document.querySelector<HTMLElement>(".result-count");
      const emptyEl = document.querySelector<HTMLElement>(".empty-state");
      const orientationEl = document.querySelector<HTMLElement>(".orientation");
      const nowNotice = document.querySelector<HTMLElement>(".now-notice");
      const staleNotice = document.querySelector<HTMLElement>(".stale-notice");
      const viewButtons = [...document.querySelectorAll<HTMLButtonElement>(".view-btn")];
      const slotPicker = document.querySelector<HTMLFieldSetElement>(".slot-picker");
      const slotDay = document.querySelector<HTMLSelectElement>("[data-slot-day]");
      const slotTime = document.querySelector<HTMLInputElement>("[data-slot-time]");
      const slotQuick = document.querySelector<HTMLElement>(".slot-quick");
      const slotCustom = document.querySelector<HTMLElement>(".slot-custom");
      const slotToDay = document.querySelector<HTMLSelectElement>("[data-slot-to-day]");
      const slotToTime = document.querySelector<HTMLInputElement>("[data-slot-to-time]");
      const slotEcho = document.querySelector<HTMLElement>(".slot-echo");
      const slotError = document.querySelector<HTMLElement>(".slot-error");
      const url = document.querySelector<HTMLMetaElement>('meta[name="program-data-url"]')!.content;

      // ---- Display formatters (UTC instants in, con-local strings out) -----------------

      const dayHeadingFmt = new Intl.DateTimeFormat("en-GB", {
        timeZone: "Europe/Helsinki",
        weekday: "long",
        day: "numeric",
        month: "long",
      });
      const timeFmt = new Intl.DateTimeFormat("en-GB", {
        timeZone: "Europe/Helsinki",
        hour: "2-digit",
        minute: "2-digit",
      });
      const stampFmt = new Intl.DateTimeFormat("en-GB", {
        timeZone: "Europe/Helsinki",
        dateStyle: "medium",
        timeStyle: "short",
      });
      const inputFmt = new Intl.DateTimeFormat("sv-SE", {
        timeZone: "Europe/Helsinki",
        year: "numeric",
        month: "2-digit",
        day: "2-digit",
        hour: "2-digit",
        minute: "2-digit",
        hourCycle: "h23",
      });

      // Compact weekday for the slot echo and day dropdowns ("Fri", "Sat"…).
      const shortWeekdayFmt = new Intl.DateTimeFormat("en-GB", {
        timeZone: "Europe/Helsinki",
        weekday: "short",
      });
      // Day-dropdown option label, e.g. "Fri 24 Jul".
      const dayOptionFmt = new Intl.DateTimeFormat("en-GB", {
        timeZone: "Europe/Helsinki",
        weekday: "short",
        day: "numeric",
        month: "short",
      });

      const esc = (text: string) =>
        text.replace(
          /[&<>"']/g,
          (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" })[c]!,
        );
      const dayHeading = (day: string) => dayHeadingFmt.format(new Date(`${day}T12:00:00Z`));
      const timeRange = (start: string, end: string) =>
        `${timeFmt.format(new Date(start))}–${timeFmt.format(new Date(end))}`;
      // Instant → the {day, time} halves of a datetime, for seeding the picker's inputs.
      const toInputParts = (ms: number) => {
        const [day, time] = inputFmt.format(ms).split(" ");
        return { day: day ?? "", time: time ?? "" };
      };

      // Orientation-state date formatters (§6 empty state). A con day is a YYYY-MM-DD
      // Helsinki calendar day; noon UTC lands on that same day in Helsinki (UTC+3 in July).
      const weekdayFmt = new Intl.DateTimeFormat("en-GB", {
        timeZone: "Europe/Helsinki",
        weekday: "long",
      });
      const dayMonthFmt = new Intl.DateTimeFormat("en-GB", {
        timeZone: "Europe/Helsinki",
        day: "numeric",
        month: "long",
      });
      const dayMonthYearFmt = new Intl.DateTimeFormat("en-GB", {
        timeZone: "Europe/Helsinki",
        day: "numeric",
        month: "long",
        year: "numeric",
      });
      const monthYearFmt = new Intl.DateTimeFormat("en-GB", {
        timeZone: "Europe/Helsinki",
        month: "long",
        year: "numeric",
      });
      const dayAsDate = (day: string) => new Date(`${day}T12:00:00Z`);
      const weekdayName = (day: string) => weekdayFmt.format(dayAsDate(day));

      // "24–26 July 2026" / "31 July – 2 August 2026" / "24 July 2026", derived from the data.
      function formatDaySpan(firstDay: string, lastDay: string): string {
        if (firstDay === lastDay) return dayMonthYearFmt.format(dayAsDate(firstDay));
        const [fy, fm, fd] = firstDay.split("-");
        const [ly, lm] = lastDay.split("-");
        const ld = lastDay.split("-")[2];
        if (fy === ly && fm === lm) {
          return `${Number(fd)}–${Number(ld)} ${monthYearFmt.format(dayAsDate(lastDay))}`;
        }
        const left = fy === ly ? dayMonthFmt.format(dayAsDate(firstDay)) : dayMonthYearFmt.format(dayAsDate(firstDay));
        return `${left} – ${dayMonthYearFmt.format(dayAsDate(lastDay))}`;
      }

      // ---- Signup / capacity copy (primer §5 step 8) -----------------------------------

      // Fallback copy for a physical signupType with no configured location (a `warn`,
      // never a hard failure — see config/signup.ts). Guests still get pointed somewhere.
      const PHYSICAL_FALLBACK_LABEL = "Signup at the info desk";
      const PHYSICAL_FALLBACK_DETAIL = "Sign up on site — ask at the program information desk.";

      function signupLabel(item: ProgramItem): string {
        switch (item.signupMode) {
          case "none":
            return "No signup needed";
          case "konsti":
            return item.signupStrategy === "lottery" ? "Konsti lottery" : "Konsti signup";
          case "physical":
            return item.physicalSignupLocation?.labelEn ?? PHYSICAL_FALLBACK_LABEL;
        }
      }

      /**
       * The one-line explanation under the signup label:
       *  - none:     walk in, nothing to do.
       *  - konsti:   direct-vs-lottery, so a lottery isn't read as a confirmed seat.
       *  - physical: where to sign up, in words — never an online action.
       */
      function signupDetail(item: ProgramItem): string {
        switch (item.signupMode) {
          case "none":
            return "Just walk in — no signup required.";
          case "konsti":
            return item.signupStrategy === "lottery"
              ? "Lottery: a signup enters you in a draw — it does not confirm a seat."
              : "Direct signup: seats are given first come, first served.";
          case "physical":
            return item.physicalSignupLocation?.instructionsEn ?? PHYSICAL_FALLBACK_DETAIL;
        }
      }

      function capacityLabel(item: ProgramItem): string | null {
        switch (item.capacityStatus) {
          case "not-applicable":
            return null;
          case "available":
            return item.remainingSeats != null
              ? `${item.remainingSeats} of ${item.maxAttendance} seats left`
              : "Seats available";
          case "full":
            return "No seats left";
          case "unknown":
            return "Live seat count unavailable";
        }
      }

      /** A Konsti session known full — the one case that earns a scannable "Full" marker. */
      const isKonstiFull = (item: ProgramItem) =>
        item.signupMode === "konsti" && item.capacityStatus === "full";

      // Content warning (§7 "Content warnings surfaced", UX decision #7). Warnings range
      // from empty to paragraph-length, and some sit on walk-in games a guest can enter
      // cold — so a non-empty warning always gets a labelled indicator that reads as a
      // warning, with the full source text one tap away and never truncated. A native
      // <details> keeps it keyboard-accessible and its <summary> labels the control even
      // while collapsed, so nothing serious hides behind an unlabelled tap. The raw text
      // is rendered as-is (no taxonomy), escaped, with whitespace preserved via CSS.
      function renderContentWarning(item: ProgramItem): string {
        const warning = item.contentWarnings.trim();
        if (!warning) return "";
        return `<details class="content-warning">
          <summary>
            <span class="cw-icon" aria-hidden="true">⚠</span>
            <span class="cw-label">Content warning</span>
            <span class="cw-hint" aria-hidden="true"></span>
          </summary>
          <p class="cw-text">${esc(warning)}</p>
        </details>`;
      }

      // ---- Rendering -------------------------------------------------------------------

      // Venue-aware map link (§7 "Map links (venue-aware)", UX decision #6). On-site
      // Messukeskus venues link to the official con map (EN); off-site venues render
      // plain with an "off-site" hint so a downtown museum isn't sent to the hall map;
      // unknown venues render plain (the refresh job logs a diagnostic for review).
      function renderLocation(location: string | null | undefined): string {
        if (!location) return "—";
        const mapUrl = resolveConMapLink(location, "en");
        if (mapUrl) {
          return `<a href="${esc(mapUrl)}" rel="noopener">${esc(location)}</a>`;
        }
        const offSite = classifyVenue(location).status === "off-site";
        return `${esc(location)}${offSite ? ' <span class="off-site-note">off-site</span>' : ""}`;
      }

      function renderItem(item: ProgramItem): string {
        const capacity = capacityLabel(item);
        // gameSystem is intentionally free text: preserve the published value exactly,
        // but suppress values that contain no visible content.
        const gameSystem = item.gameSystem.trim()
          ? `<div><dt>System</dt><dd>${esc(item.gameSystem)}</dd></div>`
          : "";
        // The signup ACTION (konsti only, and never on a cancelled session): links to the
        // same Konsti item page as the info link below, but framed as the thing to do to
        // get a seat. Suppressed for none/physical so a walk-in/desk signup never looks
        // like a web action.
        const konstiLink =
          item.signupMode === "konsti" && item.signupUrl && !item.isCancelled
            ? ` <a class="konsti-link" href="${esc(item.signupUrl)}" rel="noopener">Sign up in Konsti ↗</a>`
            : "";
        // Informational Konsti page link (§7 "Konsti page link on every card", UX #4):
        // every session has a Konsti item page regardless of signup mode, shown as a
        // "full details" link. It is distinct from the signup ACTION above. On an active
        // konsti card the signup action already links to this exact page, so a second link
        // to the same destination would be confusing (UX #4) — render the info link only
        // when the signup action isn't already carrying the guest to Konsti.
        const konstiPageLink = konstiLink
          ? ""
          : `<p class="konsti-page"><a class="konsti-page-link" href="${esc(item.konstiPageUrl)}" rel="noopener">View full details on Konsti ↗</a></p>`;
        // Venue-aware map link (§7, UX decision #6): only Messukeskus (on-site) venues
        // get the con-map link. Off-site venues (museums, parks, pre-con spaces) render
        // plain with an "off-site" hint; unknown venues render plain and are surfaced by
        // the refresh job's diagnostic, never guessed onto the hall map. Copy is EN-only.
        const location = renderLocation(item.location);
        return `<li class="session ${item.isCancelled ? "cancelled" : ""}"
          data-start="${esc(item.start)}"
          data-end="${esc(item.end)}"
          data-cancelled="${String(item.isCancelled)}"
          data-revolving="${String(item.isRevolvingDoor)}"
          data-signup-mode="${esc(item.signupMode)}"
          data-capacity="${esc(item.capacityStatus)}">
          <div class="session-head">
            <span class="time">${timeRange(item.start, item.end)}</span>
            <h3 class="title">${esc(item.title)}</h3>
            ${item.isCancelled ? '<span class="badge cancelled-badge">Cancelled</span>' : ""}
            ${!item.isCancelled && isKonstiFull(item) ? '<span class="badge full-badge">Full</span>' : ""}
          </div>
          ${
            !item.isCancelled && item.isRevolvingDoor
              ? '<p class="revolving-note">You can join mid-session.</p>'
              : ""
          }
          ${item.shortDescription ? `<p class="short">${esc(item.shortDescription)}</p>` : ""}
          ${renderContentWarning(item)}
          <dl class="facts">
            ${gameSystem}
            <div><dt>Location</dt><dd>${location}</dd></div>
            <div>
              <dt>Signup</dt>
              <dd>
                <span class="signup-label">${esc(signupLabel(item))}</span>${konstiLink}
                <span class="signup-detail">${esc(signupDetail(item))}</span>
              </dd>
            </div>
            ${capacity ? `<div><dt>Capacity</dt><dd>${esc(capacity)}</dd></div>` : ""}
          </dl>
          ${konstiPageLink}
        </li>`;
      }

      function renderProgram(data: ProgramData): void {
        // Sort by start, then group into day sections.
        const sorted = [...data.items].sort((a, b) => a.start.localeCompare(b.start));
        const days: { day: string; items: ProgramItem[] }[] = [];
        for (const item of sorted) {
          const bucket = days.find((d) => d.day === item.day);
          if (bucket) bucket.items.push(item);
          else days.push({ day: item.day, items: [item] });
        }
        programRoot.innerHTML = days
          .map(
            (group) =>
              `<section class="day" data-day="${esc(group.day)}"><h2>${esc(dayHeading(group.day))}</h2>` +
              `<ul class="sessions">${group.items.map(renderItem).join("")}</ul></section>`,
          )
          .join("");
      }

      // ---- Filtering -------------------------------------------------------------------
      // Rebuilt from the rendered DOM so the pure classifiers stay the single source of
      // truth for what counts as joinable.

      let sessions: { el: HTMLLIElement; input: TimeWindowInput }[] = [];
      let daySections: HTMLElement[] = [];

      const params = new URLSearchParams(location.search);
      const { nowMs, overridden } = resolveNow(params.get("now"), Date.now());
      const hasWindowParams = params.has("from") || params.has("to");
      let selectedWindow = resolveWindow(params.get("from"), params.get("to"), nowMs);

      function collectSessions(): void {
        sessions = [...programRoot.querySelectorAll<HTMLLIElement>(".session")].map((el) => ({
          el,
          input: {
            start: el.dataset.start ?? "",
            end: el.dataset.end ?? "",
            isCancelled: el.dataset.cancelled === "true",
            isRevolvingDoor: el.dataset.revolving === "true",
            signupMode: el.dataset.signupMode,
            capacityStatus: el.dataset.capacity,
          } as TimeWindowInput,
        }));
        daySections = [...programRoot.querySelectorAll<HTMLElement>(".day")];
      }

      function ensureBadge(el: HTMLLIElement): HTMLSpanElement {
        let badge = el.querySelector<HTMLSpanElement>(".window-badge");
        if (!badge) {
          badge = document.createElement("span");
          badge.className = "badge window-badge";
          el.querySelector(".session-head")?.appendChild(badge);
        }
        return badge;
      }

      function windowLabel(overlap: string, startMs: number): string {
        if (overlap === "join-in-progress") return "In progress · join anytime";
        const mins = Math.round((startMs - nowMs) / 60_000);
        return mins <= 0 ? "Starting now" : `Starts in ${mins} min`;
      }

      const clearBadge = (el: HTMLLIElement) => el.querySelector(".window-badge")?.remove();

      // Hide any day heading whose sessions are all filtered out.
      function syncDayHeadings(): void {
        for (const section of daySections) {
          const anyVisible = [...section.querySelectorAll<HTMLLIElement>(".session")].some(
            (el) => !el.hidden,
          );
          section.hidden = !anyVisible;
        }
      }

      // Show every session (the honest baseline); the filtered views narrow from here.
      function revealAll(): void {
        for (const { el } of sessions) {
          el.hidden = false;
          clearBadge(el);
        }
        for (const section of daySections) section.hidden = false;
        if (emptyEl) emptyEl.hidden = true;
        if (countEl) countEl.textContent = `${sessions.length} sessions`;
      }

      // Apply a per-session predicate, badge the kept ones, and report the count/empty state.
      function applyFilter(
        keep: (input: TimeWindowInput) => { included: boolean; badge: string | null },
        summarise: (shown: number) => string,
        emptyText: string,
      ): number {
        let shown = 0;
        for (const { el, input } of sessions) {
          const { included, badge } = keep(input);
          el.hidden = !included;
          if (included) {
            shown += 1;
            if (badge) ensureBadge(el).textContent = badge;
            else clearBadge(el);
          } else {
            clearBadge(el);
          }
        }
        syncDayHeadings();
        if (emptyEl) {
          emptyEl.textContent = emptyText;
          emptyEl.hidden = shown > 0;
        }
        if (countEl) countEl.textContent = summarise(shown);
        return shown;
      }

      // ---- Orientation empty state (§6, UX decision #2) --------------------------------
      // When the joinable-soon default legitimately resolves to zero, orient the guest
      // instead of showing a bare "no results": when the con runs (dates DERIVED from the
      // data span), what's on later today, and a one-tap route to the full program / next
      // active day. The model is data-derived and depends only on the fixed resolved now,
      // so it is built once at boot and merely toggled thereafter.

      let orientation: OrientationModel | null = null;

      // Switch to the full program and scroll a given con day into view.
      function jumpToDay(day: string): void {
        setView("all");
        programRoot.querySelector<HTMLElement>(`.day[data-day="${CSS.escape(day)}"]`)
          ?.scrollIntoView({ behavior: "smooth", block: "start" });
      }

      function renderOrientation(model: OrientationModel): void {
        if (!orientationEl) return;
        const parts: string[] = [
          '<p class="orientation-lead">Nothing is joinable in the next hour right now — ' +
            "here's what's coming up.</p>",
        ];

        if (model.mainConSpan) {
          const { firstDay, lastDay } = model.mainConSpan;
          const weekdays =
            firstDay === lastDay
              ? weekdayName(firstDay)
              : `${weekdayName(firstDay)}–${weekdayName(lastDay)}`;
          parts.push(
            `<p>The main convention runs <strong>${esc(weekdays)}, ` +
              `${esc(formatDaySpan(firstDay, lastDay))}</strong>.` +
              (model.isPreConvention
                ? " It's currently pre-convention week — a lighter program of early sessions."
                : "") +
              "</p>",
          );
        }

        if (model.laterToday.count > 0 && model.laterToday.nextStartMs != null) {
          const n = model.laterToday.count;
          parts.push(
            `<p><strong>${n}</strong> more session${n === 1 ? "" : "s"} ` +
              `${n === 1 ? "starts" : "start"} later today — the next at ` +
              `<strong>${esc(timeFmt.format(model.laterToday.nextStartMs))}</strong> (Helsinki).</p>`,
          );
        }

        const actions = ['<button type="button" class="orientation-action" data-action="all">See the full program</button>'];
        if (model.laterToday.count > 0 && model.today) {
          actions.push(
            `<button type="button" class="orientation-action" data-action="jump" data-day="${esc(model.today)}">` +
              "Jump to later today</button>",
          );
        }
        if (model.nextActiveDay) {
          const d = model.nextActiveDay;
          actions.push(
            `<button type="button" class="orientation-action" data-action="jump" data-day="${esc(d.day)}">` +
              `Next: ${esc(weekdayName(d.day))} ${esc(dayMonthFmt.format(dayAsDate(d.day)))} ` +
              `(${d.count} session${d.count === 1 ? "" : "s"})</button>`,
          );
        }
        parts.push(`<div class="orientation-actions">${actions.join("")}</div>`);

        orientationEl.innerHTML = parts.join("");
      }

      function render(view: View): void {
        // The orientation state belongs to the empty joinable-soon default only.
        if (orientationEl) orientationEl.hidden = true;
        if (view === "all") {
          revealAll();
        } else if (view === "walkins") {
          applyFilter(
            (input) => ({ included: isWalkInNow(input, nowMs), badge: "Happening now" }),
            (shown) => (shown === 0 ? "No walk-in games open now" : `${shown} open for walk-ins now`),
            "No walk-in games are running right now. Try Joinable soon or All sessions.",
          );
        } else if (view === "slot") {
          if (!selectedWindow.active) {
            applyFilter(
              () => ({ included: false, badge: null }),
              () => "Choose a start day and time",
              "Enter a start day and time to choose a window.",
            );
            return;
          }
          applyFilter(
            (input) => {
              const { included, overlap } = classifyInWindow(
                input,
                selectedWindow.fromMs,
                selectedWindow.toMs,
              );
              return {
                included,
                badge: included ? windowLabel(overlap, Date.parse(input.start)) : null,
              };
            },
            (shown) =>
              shown === 0
                ? "No joinable sessions in this time slot"
                : `${shown} joinable in your time slot`,
            "Nothing joinable in this time slot. Try another time or All sessions.",
          );
        } else {
          const shown = applyFilter(
            (input) => {
              const { included, overlap } = classifyJoinableSoon(input, nowMs);
              return {
                included,
                badge: included ? windowLabel(overlap, Date.parse(input.start)) : null,
              };
            },
            (shown) => (shown === 0 ? "No joinable sessions" : `${shown} joinable in the next hour`),
            "Nothing joinable in the next hour. Switch to All sessions to see the full program.",
          );
          // Zero joinable-soon is legitimate (pre-con / early in the day): orient the guest
          // instead of leaving the bare empty-state line to carry the whole first impression.
          if (shown === 0 && orientation) {
            renderOrientation(orientation);
            orientationEl!.hidden = false;
            if (emptyEl) emptyEl.hidden = true;
          }
        }
      }

      function setView(view: View): void {
        for (const btn of viewButtons) {
          btn.setAttribute("aria-pressed", String(btn.dataset.view === view));
        }
        if (slotPicker) slotPicker.hidden = view !== "slot";
        render(view);
      }

      // ---- "My time slot" picker (§6, issue-05) --------------------------------------
      // `to` is chosen relative to `from`: a +Nh quick option (default +3h), or an
      // explicit Custom window. The pure model (classify/slot.ts) owns the maths and the
      // inverted-window correction; this wires it to the day/time/quick controls.

      let activeQuick: QuickOption = 3;

      // "Showing Fri 13:00–16:00" (or across midnight, "Fri 23:00 – Sat 02:00"), so a
      // +Nh quick option is never opaque (§6 "Echo the resolved window back").
      function windowEcho(fromMs: number, toMs: number): string {
        const fromDay = shortWeekdayFmt.format(fromMs);
        const toDay = shortWeekdayFmt.format(toMs);
        const f = timeFmt.format(fromMs);
        const t = timeFmt.format(toMs);
        return fromDay === toDay
          ? `Showing ${fromDay} ${f}–${t}`
          : `Showing ${fromDay} ${f} – ${toDay} ${t}`;
      }

      function populateDaySelect(select: HTMLSelectElement, days: string[]): void {
        select.innerHTML = days
          .map(
            (day) => `<option value="${esc(day)}">${esc(dayOptionFmt.format(dayAsDate(day)))}</option>`,
          )
          .join("");
      }

      function updateQuickButtons(): void {
        for (const btn of slotQuick?.querySelectorAll<HTMLButtonElement>(".quick-btn") ?? []) {
          btn.setAttribute("aria-pressed", String(btn.dataset.quick === String(activeQuick)));
        }
      }

      function readSelection(): SlotSelection {
        return {
          fromDay: slotDay?.value ?? "",
          fromTime: slotTime?.value ?? "",
          quick: activeQuick,
          toDay: slotToDay?.value ?? "",
          toTime: slotToTime?.value ?? "",
        };
      }

      // Resolve the current controls into the active window, reflect any correction back
      // into the inputs, echo the resolved window, persist it to the URL, and re-filter.
      function applySlot(): void {
        const resolved = resolveSlot(readSelection());
        selectedWindow = { fromMs: resolved.fromMs, toMs: resolved.toMs, active: resolved.active };

        if (resolved.corrected && slotToDay && slotToTime) {
          slotToDay.value = resolved.toDay;
          slotToTime.value = resolved.toTime;
        }
        if (slotError) {
          slotError.hidden = resolved.active;
          slotError.textContent = "Enter a start day and time to choose a window.";
        }
        if (slotEcho) {
          slotEcho.hidden = !resolved.active;
          if (resolved.active) slotEcho.textContent = windowEcho(resolved.fromMs, resolved.toMs);
        }
        if (resolved.active) {
          params.set("from", new Date(resolved.fromMs).toISOString());
          params.set("to", new Date(resolved.toMs).toISOString());
          history.replaceState(null, "", `${location.pathname}?${params}${location.hash}`);
        }
        render("slot");
      }

      // Populate the day dropdowns + quick buttons, seed the selection (from ?from/?to
      // when present, else the data-derived default), and resolve the first window.
      function initSlotPicker(items: ProgramItem[]): void {
        const days = conDays(items);
        if (slotDay) populateDaySelect(slotDay, days);
        if (slotToDay) populateDaySelect(slotToDay, days);
        if (slotQuick) {
          slotQuick.innerHTML =
            QUICK_HOURS.map(
              (h) => `<button type="button" class="quick-btn" data-quick="${h}">+${h}h</button>`,
            ).join("") +
            '<button type="button" class="quick-btn" data-quick="custom">Custom</button>';
        }

        const seed = selectedWindow.active
          ? selectionFromWindow(selectedWindow.fromMs, selectedWindow.toMs)
          : resolveDefaultSelection(items, nowMs);

        activeQuick = seed.quick;
        if (slotDay && days.includes(seed.fromDay)) slotDay.value = seed.fromDay;
        if (slotTime) slotTime.value = seed.fromTime;
        if (slotToDay && days.includes(seed.toDay)) slotToDay.value = seed.toDay;
        if (slotToTime) slotToTime.value = seed.toTime;
        updateQuickButtons();
        if (slotCustom) slotCustom.hidden = activeQuick !== "custom";

        applySlot();
      }

      // ---- Boot ------------------------------------------------------------------------

      const result = await loadProgramData({ url, cache: localStorageProgramCache() });

      if (result.status === "unavailable-first-run") {
        statusEl.textContent = "Program unavailable";
        programRoot.innerHTML =
          '<p class="notice">The program cannot be loaded right now. Connect to the internet ' +
          "and reload; after one successful visit it remains available offline.</p>";
      } else {
        const data = result.data;
        renderProgram(data);
        collectSessions();

        // Data-derived orientation for the empty joinable-soon default (§6, UX #2).
        orientation = buildOrientation(data.items, nowMs);
        orientationEl?.addEventListener("click", (event) => {
          const btn = (event.target as HTMLElement).closest<HTMLElement>(".orientation-action");
          if (!btn) return;
          if (btn.dataset.action === "all") setView("all");
          else if (btn.dataset.action === "jump" && btn.dataset.day) jumpToDay(btn.dataset.day);
        });

        const cacheNote = result.status === "ready-cache" ? " · offline cached copy" : "";
        statusEl.textContent =
          `${data.items.length} gaming sessions · program as of ` +
          `${stampFmt.format(new Date(data.generatedAt))} (Helsinki)${cacheNote}`;

        // Seed and resolve the "My time slot" picker (day + relative +Nh window, §6).
        initSlotPicker(data.items);

        // Reveal the JS-only controls and wire them up.
        controls?.removeAttribute("hidden");
        for (const btn of viewButtons) {
          btn.addEventListener("click", () => setView(btn.dataset.view as View));
        }
        // Changing the day gives that day its own sensible default start time, then
        // recomputes the window; time/custom changes just re-resolve.
        slotDay?.addEventListener("change", () => {
          if (slotTime && slotDay) slotTime.value = defaultFromTime(data.items, slotDay.value, nowMs);
          applySlot();
        });
        slotTime?.addEventListener("change", applySlot);
        slotToDay?.addEventListener("change", applySlot);
        slotToTime?.addEventListener("change", applySlot);
        slotQuick?.addEventListener("click", (event) => {
          const btn = (event.target as HTMLElement).closest<HTMLButtonElement>(".quick-btn");
          if (!btn) return;
          const q = btn.dataset.quick;
          activeQuick = q === "custom" ? "custom" : (Number(q) as QuickOption);
          // Entering Custom: seed the explicit inputs from the window just shown, so the
          // guest adjusts from a sensible value rather than an empty field.
          if (
            activeQuick === "custom" &&
            slotToDay &&
            slotToTime &&
            Number.isFinite(selectedWindow.toMs)
          ) {
            const p = toInputParts(selectedWindow.toMs);
            if (conDays(data.items).includes(p.day)) slotToDay.value = p.day;
            slotToTime.value = p.time;
          }
          updateQuickButtons();
          if (slotCustom) slotCustom.hidden = activeQuick !== "custom";
          applySlot();
        });

        if (overridden && nowNotice) {
          nowNotice.hidden = false;
          nowNotice.textContent =
            `Testing as if it were ${stampFmt.format(nowMs)} (Helsinki) · ?now= override active`;
        }

        // Step 9: warn near the action UI when the snapshot has aged past 15 minutes.
        // Uses the same resolved `nowMs` as the filters, so a `?now=` past the stamp shows stale.
        if (staleNotice) {
          const generatedAtMs = Date.parse(data.generatedAt);
          if (!Number.isNaN(generatedAtMs)) {
            const { isStale, ageMinutes } = classifyFreshness(generatedAtMs, nowMs);
            staleNotice.hidden = !isStale;
            if (isStale) {
              staleNotice.textContent =
                `Heads up: this program snapshot is ${ageMinutes} minutes old ` +
                `(as of ${stampFmt.format(generatedAtMs)}, Helsinki). ` +
                `Seat availability and cancellations may have changed since then — ` +
                `check Konsti before relying on a seat.`;
            }
          }
        }

        setView(hasWindowParams ? "slot" : "soon");
      }

      if ("serviceWorker" in navigator) navigator.serviceWorker.register("/service-worker.js");
    </script>

    <!-- The program cards and several controls are created by the client script, so this
         page stylesheet must also match elements without Astro's compile-time scope ID. -->
    <style is:global>
      :root {
        --fg: #1a1a1a;
        --muted: #666;
        --line: #e2e2e2;
        --accent: #7a1f2b;
      }

      body {
        font-family: system-ui, -apple-system, sans-serif;
        color: var(--fg);
        line-height: 1.4;
        max-width: 46rem;
        margin: 0 auto;
        padding: 1.5rem 1rem 4rem;
      }

      .page-header h1 {
        margin: 0 0 0.25rem;
        color: var(--accent);
      }

      .meta {
        margin: 0;
        color: var(--muted);
        font-size: 0.9rem;
      }

      .day h2 {
        font-size: 1.1rem;
        margin: 2rem 0 0.5rem;
        padding-bottom: 0.25rem;
        border-bottom: 2px solid var(--line);
      }

      .sessions {
        list-style: none;
        margin: 0;
        padding: 0;
      }

      .session {
        padding: 0.9rem 0;
        border-bottom: 1px solid var(--line);
      }

      .session.cancelled {
        opacity: 0.6;
      }

      .session-head {
        display: flex;
        flex-wrap: wrap;
        align-items: baseline;
        gap: 0.5rem;
      }

      .time {
        font-variant-numeric: tabular-nums;
        color: var(--muted);
        font-size: 0.9rem;
        min-width: 6.5rem;
      }

      .title {
        margin: 0;
        font-size: 1.05rem;
      }

      .session.cancelled .title {
        text-decoration: line-through;
      }

      .badge {
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.03em;
        padding: 0.1rem 0.4rem;
        border-radius: 0.25rem;
      }

      .cancelled-badge {
        background: #fbe3e3;
        color: var(--accent);
      }

      .window-badge {
        background: #e7f0e7;
        color: #2f6b34;
      }

      .controls {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.75rem;
        margin-top: 0.75rem;
      }

      .slot-picker {
        flex-basis: 100%;
        display: flex;
        flex-direction: column;
        gap: 0.7rem;
        margin: 0;
        padding: 0.75rem;
        border: 1px solid var(--line);
        border-radius: 0.4rem;
      }

      .slot-picker[hidden] {
        display: none;
      }

      .slot-picker legend {
        font-size: 0.85rem;
        font-weight: 600;
        padding: 0 0.25rem;
      }

      .slot-from,
      .slot-custom {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
      }

      .slot-field {
        display: grid;
        gap: 0.2rem;
        font-size: 0.8rem;
        color: var(--muted);
      }

      .slot-field select,
      .slot-field input {
        font: inherit;
        color: var(--fg);
        padding: 0.35rem 0.45rem;
        border: 1px solid var(--line);
        border-radius: 0.3rem;
        background: #fff;
      }

      .slot-to-label {
        display: block;
        font-size: 0.8rem;
        color: var(--muted);
        margin-bottom: 0.35rem;
      }

      .slot-quick {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
      }

      .quick-btn {
        appearance: none;
        border: 1px solid var(--line);
        background: #fff;
        color: var(--fg);
        font: inherit;
        font-size: 0.9rem;
        padding: 0.4rem 0.7rem;
        border-radius: 0.3rem;
        cursor: pointer;
      }

      .quick-btn[aria-pressed="true"] {
        background: var(--accent);
        border-color: var(--accent);
        color: #fff;
      }

      .slot-custom {
        margin-top: 0.6rem;
      }

      .slot-custom[hidden] {
        display: none;
      }

      .slot-echo {
        margin: 0;
        font-size: 0.9rem;
        font-weight: 600;
      }

      .slot-echo[hidden] {
        display: none;
      }

      .slot-error {
        margin: 0;
        color: var(--accent);
        font-size: 0.85rem;
      }

      .views {
        display: inline-flex;
        border: 1px solid var(--line);
        border-radius: 0.4rem;
        overflow: hidden;
      }

      .view-btn {
        appearance: none;
        border: 0;
        background: #fff;
        color: var(--fg);
        font: inherit;
        font-size: 0.9rem;
        padding: 0.35rem 0.75rem;
        cursor: pointer;
      }

      .view-btn + .view-btn {
        border-left: 1px solid var(--line);
      }

      .view-btn[aria-pressed="true"] {
        background: var(--accent);
        color: #fff;
      }

      .result-count {
        margin: 0;
        color: var(--muted);
        font-size: 0.9rem;
      }

      .now-notice {
        margin: 0.5rem 0 0;
        padding: 0.4rem 0.6rem;
        background: #fff6e0;
        border-radius: 0.3rem;
        font-size: 0.85rem;
        color: #7a5b00;
      }

      .stale-notice {
        margin: 0.5rem 0 0;
        padding: 0.5rem 0.7rem;
        background: #fbe3e3;
        border-left: 3px solid var(--accent);
        border-radius: 0.3rem;
        font-size: 0.85rem;
        color: var(--accent);
      }

      .empty-state {
        color: var(--muted);
        padding: 1.5rem 0;
      }

      .orientation {
        margin: 1.25rem 0;
        padding: 1rem 1.1rem;
        background: #f6f1f2;
        border-left: 3px solid var(--accent);
        border-radius: 0.4rem;
      }

      .orientation p {
        margin: 0 0 0.55rem;
        font-size: 0.95rem;
      }

      .orientation-lead {
        font-weight: 600;
      }

      .orientation-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: 0.85rem;
      }

      .orientation-action {
        appearance: none;
        border: 1px solid var(--accent);
        background: #fff;
        color: var(--accent);
        font: inherit;
        font-size: 0.85rem;
        padding: 0.4rem 0.7rem;
        border-radius: 0.4rem;
        cursor: pointer;
      }

      .orientation-action[data-action="all"] {
        background: var(--accent);
        color: #fff;
      }

      .notice {
        margin: 1.5rem 0;
        padding: 0.7rem;
        background: #fbe3e3;
        color: var(--accent);
        border-radius: 0.25rem;
      }

      .short {
        margin: 0.4rem 0 0.5rem;
        color: var(--fg);
      }

      .facts {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 0.15rem 0.75rem;
        margin: 0;
        font-size: 0.9rem;
      }

      .facts > div {
        display: contents;
      }

      .facts dt {
        color: var(--muted);
      }

      .facts dd {
        margin: 0;
        min-width: 0;
        overflow-wrap: anywhere;
      }

      .intro {
        margin: 0.75rem 0 0;
        font-size: 0.9rem;
        color: var(--fg);
      }

      a {
        color: var(--accent);
      }

      .full-badge {
        background: #f0dede;
        color: var(--accent);
      }

      .revolving-note {
        margin: 0.35rem 0 0;
        font-size: 0.85rem;
        font-weight: 600;
        color: #2f6b34;
      }

      .signup-detail {
        display: block;
        color: var(--muted);
        font-size: 0.85rem;
      }

      /* Informational Konsti page link (§7, UX #4): a quiet "full details" link on every
         card, visually secondary to the signup action so the two never read as rival CTAs. */
      .konsti-page {
        margin: 0.5rem 0 0;
        font-size: 0.85rem;
      }

      /* Content warning (§7): a labelled, caution-styled indicator that stays legible
         while collapsed and expands to the full, untruncated source text. */
      .content-warning {
        margin: 0.5rem 0;
        border: 1px solid #e0b400;
        border-left: 3px solid #b57e00;
        border-radius: 0.3rem;
        background: #fff9e6;
      }

      .content-warning summary {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.4rem 0.6rem;
        cursor: pointer;
        font-size: 0.85rem;
        font-weight: 600;
        color: #7a5b00;
        list-style: none;
      }

      .content-warning summary::-webkit-details-marker {
        display: none;
      }

      .cw-icon {
        font-size: 0.95rem;
      }

      .cw-label {
        text-transform: uppercase;
        letter-spacing: 0.03em;
        font-size: 0.75rem;
      }

      .cw-hint {
        margin-left: auto;
        font-weight: 600;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.03em;
        opacity: 0.75;
      }

      .cw-hint::after {
        content: "Show";
      }

      .content-warning[open] .cw-hint::after {
        content: "Hide";
      }

      .cw-text {
        margin: 0;
        padding: 0 0.6rem 0.55rem;
        font-size: 0.85rem;
        color: var(--fg);
        white-space: pre-wrap;
        overflow-wrap: anywhere;
      }

      .off-site-note {
        margin-left: 0.35rem;
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.03em;
        color: var(--muted);
      }
    </style>
  </body>
</html>
